# ── Copie para .env (local) ou cadastre nas variáveis de ambiente do host ──

# Chave de sessão do Flask (gere uma: python -c "import secrets;print(secrets.token_hex(32))")
SECRET_KEY=

# Google OAuth + Calendar (Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Groq (https://console.groq.com/keys) — usado para extrair tarefas dos arquivos
GROQ_API_KEY=

# ── Produção ──────────────────────────────────────────────────────────────
# Liga cookie seguro (exige HTTPS). Use 1 em produção, deixe vazio/0 no local.
SESSION_COOKIE_SECURE=1

# Fuso usado nos eventos do Google Agenda
CAL_TIMEZONE=America/Sao_Paulo

# Caminho do banco (em hosts com disco persistente, aponte para o disco)
# DB_PATH=/var/data/orgeral.db

# NUNCA use 1 em produção (debugger remoto = risco de RCE)
FLASK_DEBUG=0
